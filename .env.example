# Copy to .env and fill in. Never commit the real .env.

# Neon Postgres — use the POOLED connection string (host contains "-pooler").
# Neon Console → Project → Connection Details → Pooled connection.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# Shared secret guarding the admin POST routes (sent as the x-admin-key header
# from the "İçerik Ekle" page). Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_KEY=change-me

# API port. Locally 3000; Railway sets PORT automatically.
PORT=3000
